#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "pre-commit: shellcheck was not found; skipping shell lint." >&2
  echo "Install it to enable this check. On macOS: brew install shellcheck" >&2
  exit 0
fi

files=()
while IFS= read -r file; do
  [ -f "$file" ] || continue
  files+=("$file")
done < <(scripts/list-shell-files)

if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

echo "pre-commit: running shellcheck on ${#files[@]} shell files"
shellcheck "${files[@]}"
